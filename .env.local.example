# Supabase Credentials (Required for database and authentication)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# News API Key (Required for fetching brand/keyword mentions)
GNEWS_API_KEY=your-gnews-api-key

# AI API Keys (Optional: if not provided, the application falls back to Heuristic/Mock engines)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
